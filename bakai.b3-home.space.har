            "text": "{\n    \"MENU\": {\n        \"HOME\": \"Startseite\",\n        \"DASHBOARD\": \"Dashboard\",\n        \"DEVELOPER\": \"Entwickler\",\n        \"API_DOCS\": \"API-Dokumentation\"\n    },\n    \"AUTH\": {\n        \"LOGIN\": {\n            \"WELCOME\": \"Willkommen bei BAKAI!\",\n            \"SUBTITLE\": \"Anmelden, um fortzufahren\",\n            \"EMAIL\": \"E-Mail\",\n            \"EMAIL_PLACEHOLDER\": \"E-Mail-Adresse\",\n            \"PASSWORD\": \"Passwort\",\n            \"PASSWORD_PLACEHOLDER\": \"Passwort\",\n            \"REMEMBER_ME\": \"Angemeldet bleiben\",\n            \"FORGOT_PASSWORD\": \"Passwort vergessen?\",\n            \"SIGN_IN\": \"Anmelden\"\n        },\n        \"ERROR\": {\n            \"TITLE\": \"Fehler aufgetreten\",\n            \"SUBTITLE\": \"Die angeforderte Ressource ist nicht verfügbar.\",\n            \"GO_TO_DASHBOARD\": \"Zum Dashboard\"\n        },\n        \"ACCESS\": {\n            \"TITLE\": \"Zugriff verweigert\",\n            \"SUBTITLE\": \"Sie haben nicht die erforderlichen Berechtigungen. Bitte kontaktieren Sie die Administratoren.\",\n            \"GO_TO_DASHBOARD\": \"Zum Dashboard\"\n        }\n    },\n    \"DASHBOARD\": {\n        \"STATS\": {\n            \"ORDERS\": \"Bestellungen\",\n            \"SINCE_LAST_VISIT\": \"seit dem letzten Besuch\",\n            \"REVENUE\": \"Umsatz\",\n            \"SINCE_LAST_WEEK\": \"seit letzter Woche\",\n            \"CUSTOMERS\": \"Kunden\",\n            \"NEWLY_REGISTERED\": \"neu registriert\",\n            \"COMMENTS\": \"Kommentare\",\n            \"UNREAD\": \"Ungelesen\",\n            \"RESPONDED\": \"beantwortet\"\n        },\n        \"MKV_MOVER\": {\n            \"TITLE\": \"MKV Mover\",\n            \"BACKEND_NOT_REACHABLE\": \"Backend nicht erreichbar\",\n            \"BACKEND_NOT_RUNNING\": \"Bitte stelle sicher, dass das Backend läuft.\",\n            \"SOURCE_FOLDER\": \"Quellordner\",\n            \"SOURCE_PLACEHOLDER\": \"z. B. D:\\\\Video